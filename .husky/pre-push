#!/bin/sh

echo "Running pre-push checks..."

# Lint check — block on errors only
echo "Running ESLint..."
npx eslint app/ components/ lib/ middleware.ts --ext .ts,.tsx --quiet
if [ $? -ne 0 ]; then
  echo ""
  echo "ESLint errors found. Fix them before pushing."
  exit 1
fi

# Type check with sufficient memory for large codebase
echo "Running type check..."
NODE_OPTIONS="--max-old-space-size=4096" npx tsc --noEmit --skipLibCheck
if [ $? -ne 0 ]; then
  echo ""
  echo "TypeScript errors found. Fix them before pushing."
  exit 1
fi

echo "All pre-push checks passed!"
