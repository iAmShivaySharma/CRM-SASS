#!/bin/sh

echo "Running pre-push checks..."

# ESLint — catches bugs, security issues, bad patterns, unused code
echo "Running ESLint..."
npx eslint app/ components/ lib/ middleware.ts --ext .ts,.tsx --quiet
if [ $? -ne 0 ]; then
  echo ""
  echo "ESLint errors found. Fix them before pushing."
  exit 1
fi

echo "All pre-push checks passed!"
echo ""
echo "Note: Full build + type check runs in CI pipeline."
